# ============================================================
# Schwab API Credentials
# Obtener en: https://developer.schwab.com
# ============================================================
SCHWAB_CLIENT_ID=tu_client_id_aqui
SCHWAB_CLIENT_SECRET=tu_client_secret_aqui

# Redirect URI registrada en el portal de Schwab
# IMPORTANTE: debe incluir el puerto 8182 y coincidir EXACTAMENTE
# con la Callback URL configurada en developer.schwab.com
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182

# ============================================================
# Configuración general (opcional)
# ============================================================

# Intervalo de refresco en segundos (default: 60)
REFRESH_INTERVAL=60

# Directorio de salida para los archivos Excel
OUTPUT_DIR=output
